# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Meta / Facebook ──────────────────────────────────────────────────────────
# Your custom webhook verify token (any random string you choose)
META_VERIFY_TOKEN=your_random_verify_token_here

# WhatsApp Cloud API — from Meta Developer Console > WhatsApp > API Setup
WA_ACCESS_TOKEN=your_whatsapp_access_token
# The Phone Number ID (not the phone number itself)
WA_PHONE_NUMBER_ID=your_phone_number_id

# Instagram Messaging — Page Access Token for your Instagram Business account
IG_PAGE_ACCESS_TOKEN=your_instagram_page_access_token

# Facebook Messenger — Page Access Token for your Facebook Page
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Password staff uses to log into /admin
ADMIN_PASSWORD=choose_a_strong_password
# Random secret for session cookie (generate with: openssl rand -hex 32)
ADMIN_SESSION_SECRET=generate_random_secret_here

# ─── Database ────────────────────────────────────────────────────────────────
# Optional: override default SQLite file location
# DB_PATH=/absolute/path/to/salon.db

# ─── Branch Info ─────────────────────────────────────────────────────────────
BRANCH1_NAME=Branch 1 - City Center
BRANCH1_ADDRESS=123 Main Street, City Center, Dubai
BRANCH1_PHONE=+971 50 000 0001
BRANCH1_MAP_LINK=https://maps.google.com/?q=your+branch+1+address

BRANCH2_NAME=Branch 2 - Uptown
BRANCH2_ADDRESS=456 Park Avenue, Jumeirah, Dubai
BRANCH2_PHONE=+971 50 000 0002
BRANCH2_MAP_LINK=https://maps.google.com/?q=your+branch+2+address

# ─── Calendly ────────────────────────────────────────────────────────────────
CALENDLY_BRANCH1=https://calendly.com/your-branch1-account/appointment
CALENDLY_BRANCH2=https://calendly.com/your-branch2-account/appointment

# ─── Chat Widget ──────────────────────────────────────────────────────────────
# Allowed origins for the /api/chat endpoint. Use * to allow all websites,
# or set to your salon website domain for production: https://yoursalon.com
WIDGET_ALLOWED_ORIGINS=*
